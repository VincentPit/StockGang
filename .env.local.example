# Copy this to .env.local for local Next.js development (npm run dev)
# Do NOT commit .env.local — it is gitignored by Next.js automatically.

# Where the Next.js server proxies /api/* requests (server-side rewrite)
API_BASE_URL=http://localhost:8000

# Public env var available in browser JS (must restart dev server after changing)
NEXT_PUBLIC_API_URL=http://localhost:8000
