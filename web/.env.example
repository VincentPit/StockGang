# ─── Environment ──────────────────────────────────────────────
ENV=development   # development | paper | live

# ─── API Server ───────────────────────────────────────────────
API_PORT=8000
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000   # comma-separated for multiple

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=myquant
POSTGRES_USER=myquant
POSTGRES_PASSWORD=changeme

# ─── Tushare ──────────────────────────────────────────────────
TUSHARE_TOKEN=your_tushare_token_here

# ─── Futu OpenAPI (港股 / 美股) ──────────────────────────────
FUTU_HOST=127.0.0.1
FUTU_PORT=11111
FUTU_TRADE_PASSWORD=your_trade_password
FUTU_TRADE_PASSWORD_MD5=your_md5_hash

# ─── Interactive Brokers ──────────────────────────────────────
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# ─── WeChat Work (企业微信) alerts ────────────────────────────
WECHAT_WORK_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY

# ─── Risk Parameters ──────────────────────────────────────────
MAX_POSITION_PCT=0.20          # Max single position as % of NAV
MAX_SECTOR_PCT=0.40            # Max sector exposure
DAILY_DRAWDOWN_LIMIT=-0.03     # -3% daily loss → halt
VAR_LIMIT=0.02                 # 1-day 95% VaR limit as % of NAV
MAX_ORDERS_PER_MINUTE=10       # Throttle limit
